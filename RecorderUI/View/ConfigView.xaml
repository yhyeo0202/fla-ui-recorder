<UserControl x:Class="RecorderUI.View.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RecorderUI.View"
             xmlns:component="clr-namespace:RecorderUI.Component"
             xmlns:core="clr-namespace:RecorderUI.Core"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <core:BindingProxy x:Key="proxy" Data="{Binding}"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer
        MaxHeight="400"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Orientation="Vertical"
            Margin="20 5 20 5">
            <TextBlock
                Margin="5"
                Text="Recorder configuration"
                FontSize="20"
                FontWeight="Bold"/>
            <Separator/>
            <component:FormView
                DataContext="{Binding recorderConfigForm}"/>
            <Button
                HorizontalAlignment="Right"
                Height="20"
                Width="100"
                Margin="5"
                Visibility="{Binding addAttacherVisible}"
                Content="Add attacher"
                Command="{Binding AddAttacherCommand}"/>

            <TextBlock
                Margin="5"
                Text="Attacher configuration"
                FontSize="20"
                FontWeight="Bold"
                Visibility="{Binding attacherConfigFormVisible}"/>
            <Separator
                Visibility="{Binding attacherConfigFormVisible}"/>
            <component:FormView
                Visibility="{Binding Data.attacherConfigFormVisible, Source={StaticResource proxy}, Mode=TwoWay}"
                DataContext="{Binding attacherConfigForm}"/>
            <Button
                HorizontalAlignment="Right"
                Height="20"
                Width="100"
                Margin="5"
                Visibility="{Binding removeAttacherVisible}"
                Content="Remove attacher"
                Command="{Binding RemoveAttacherCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
